APP_ENV=production
LOG_JSON=true

# ── Managed databases (replace with your actual URLs) ─────────────────────
# Neon: https://console.neon.tech → Connection string
DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.us-east-1.aws.neon.tech/bearing_monitor?sslmode=require

# MongoDB Atlas: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URL=mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net
MONGODB_DATABASE=bearing_monitor

# Upstash Redis: https://console.upstash.com → REST URL (use rediss:// for TLS)
REDIS_URL=rediss://default:pass@xxx.upstash.io:6379

# ── App config ─────────────────────────────────────────────────────────────
API_PORT=8000
WORKER_METRICS_PORT=9102
PROMETHEUS_NAMESPACE=bearing_monitor

SEARCH_QUERIES=SKF bearing 6205,SKF bearing 6206,SKF bearing 6305
DEFAULT_LOCATIONS=chennai-tn,mumbai-mh,bengaluru-ka
OWN_SELLER_NAMES=Nisargasoft Industrial
PRICE_DROP_THRESHOLD=0.10
SCRAPE_INTERVAL_MINUTES=15

AMAZON_BASE_URL=https://www.amazon.in
INGEST_API_URL=http://api:8000
SCRAPER_ARTIFACT_DIR=artifacts/scraper_failures

# Your Vercel frontend URL
FRONTEND_ORIGIN=https://your-app.vercel.app

# ── Notifications (optional) ───────────────────────────────────────────────
SLACK_WEBHOOK_URL=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

PLAYWRIGHT_HEADLESS=true
