APP_ENV=production
LOG_JSON=true

# These stay the same since services talk to each other via Docker network
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/bearing_monitor
MONGODB_URL=mongodb://mongo:27017
MONGODB_DATABASE=bearing_monitor
REDIS_URL=redis://redis:6379/0

API_PORT=8000
WORKER_METRICS_PORT=9102
PROMETHEUS_NAMESPACE=bearing_monitor

SEARCH_QUERIES=SKF bearing 6205,SKF bearing 6206,SKF bearing 6305
DEFAULT_LOCATIONS=chennai-tn,mumbai-mh,bengaluru-ka
OWN_SELLER_NAMES=Nisargasoft Industrial,Your Distributor Name
PRICE_DROP_THRESHOLD=0.10
SCRAPE_INTERVAL_MINUTES=20

AMAZON_BASE_URL=https://www.amazon.in
INGEST_API_URL=http://api:8000
SCRAPER_ARTIFACT_DIR=artifacts/scraper_failures

# Set this to your Vercel frontend URL
FRONTEND_ORIGIN=https://your-app.vercel.app

SLACK_WEBHOOK_URL=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

PLAYWRIGHT_HEADLESS=true
